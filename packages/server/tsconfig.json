{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "types": ["@types/bun"],
    "paths": {
      "@thoughtcurrent/shared": ["../shared/src"]
    }
  },
  "include": ["src"]
}
